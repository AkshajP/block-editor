# WebSocket Server Configuration for Collaborative Editing
NEXT_PUBLIC_WS_HOST=localhost
NEXT_PUBLIC_WS_PORT=1234

# Y-WebSocket Server Persistence (local dev)
# This saves Yjs documents so clients can reconnect and continue editing
# YPERSISTENCE=./yjs-wss-db

# PostgreSQL configuration used by the collaboration server and docker-compose
# Copy or override these values in your own `.env` file.
PGHOST=localhost
PGPORT=5432
PGDATABASE=blockdb
PGUSER=blockuser
PGPASSWORD=secret
