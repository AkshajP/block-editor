# Database (Prisma — packages/db)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/collab"

# Keycloak (packages/auth — NextAuth v5 convention: AUTH_<PROVIDER>_*)
AUTH_KEYCLOAK_ID="block-editor-web"
AUTH_KEYCLOAK_SECRET="dev-secret-change-in-prod"
AUTH_KEYCLOAK_ISSUER="http://localhost:8080/realms/block-editor"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# Collaboration WebSocket server
NEXT_PUBLIC_WS_HOST=localhost
NEXT_PUBLIC_WS_PORT=1234
# Shared HMAC secret for signing WS access tokens — must match collab-server WS_SECRET
WS_SECRET=dev-ws-secret-change-in-prod
